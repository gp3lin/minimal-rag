# Ollama — host makinede çalışıyor, Docker içinden erişim
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text

# Qdrant — Docker Compose network'ü içinde container adı ile erişim
# Lokalde (Docker dışında) çalışırken QDRANT_HOST=localhost yap
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=math_papers

# Chunking parametreleri
CHUNK_SIZE=512
CHUNK_OVERLAP=50
TOP_K=5

# PostgreSQL — sohbet geçmişi
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis — semantic cache
REDIS_HOST=redis
REDIS_PORT=6379
CACHE_SIMILARITY_THRESHOLD=0.90
CACHE_TTL_SECONDS=86400
